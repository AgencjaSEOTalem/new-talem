# 1. Wyłączamy automatyczne dodawanie slasha do fizycznych folderów (kluczowe!)
DirectorySlash Off
Options -Indexes

RewriteEngine On
RewriteBase /

# 2. Wyjątek dla wp-admin - panel WordPressa MUSI mieć slash, inaczej się nie zalogujesz
RewriteCond %{REQUEST_URI} ^/blog/wp-admin$
RewriteRule ^blog/wp-admin$ /blog/wp-admin/ [R=301,L]

# 3. Jeśli ktoś wejdzie na /blog/ (ze slashem), przekieruj na /blog (bez slasha)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} ^/blog/$
RewriteRule ^blog/$ /blog [R=301,L]

# 4. Obsługa wejścia na /blog - pokaż index.php, ale nie zmieniaj adresu w przeglądarce
RewriteCond %{REQUEST_URI} ^/blog$
RewriteRule ^blog$ blog/index.php [L]

# 5. Ogólne usuwanie slasha dla całej reszty (Astro i podstrony bloga)
# Usunąłem warunek !-d, aby reguła działała też na folder /blog
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(^/blog/wp-admin)
RewriteCond %{REQUEST_URI} ^/(.+)/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# 6. Ignoruj WordPressa (dalsze przetwarzanie plików wewnątrz /blog)
RewriteCond %{REQUEST_URI} ^/blog [NC]
RewriteRule . - [L]

# 7. Obsługa plików .html bez rozszerzenia (Astro Clean URLs)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^/]+)$ $1.html [L]

ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# --- Twoje Przekierowania ---
# (Tutaj wklej resztę swoich Redirect 301, które miałeś pod spodem)

# --- Przekierowania na konkretne podstrony ---
Redirect 301 /opieka-nad-stronami-www /monitoring-wydajnosci
Redirect 301 /monitoring-pozycji /monitoring-wydajnosci
Redirect 301 /konsultacje-seo /techniczne-seo
Redirect 301 /audyty-seo /techniczne-seo
Redirect 301 /seo-copywriting /content-seo

# --- Przekierowania na stronę główną ---
Redirect 301 /reklama-ppc /
Redirect 301 /pozycjonowanie-lokalne /
Redirect 301 /pozycjonowanie-stron-www /
Redirect 301 /pozycjonowanie-z-rabatem /
Redirect 301 /projektowanie-stron-i-serwisow-www /
Redirect 301 /wydanie-kodow-authinfo /
Redirect 301 /hosting-serwery-wirtualne-ssd-bez-limitu-transferu-danych /
Redirect 301 /google-moja-firma /
Redirect 301 /optymalizacja-stron-www /
Redirect 301 /certyfikaty-ssl /
Redirect 301 /domeny-internetowe /
Redirect 301 /pozycjonowanie-zagraniczne /
Redirect 301 /cesja-domeny /
Redirect 301 /cesja-domeny/ /
Redirect 301 /zmiana-danych-abonenta /
Redirect 301 /pozycjonowanie-sklepow-internetowych /