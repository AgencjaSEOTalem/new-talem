<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(woff2|woff|ttf|otf|css|js|webp|svg|jpg|jpeg|png|gif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

Options -Indexes
DirectorySlash Off

RewriteEngine On
RewriteBase /

# Canonical URL: bez końcowego slasha (poza "/")
RewriteCond %{REQUEST_URI} !^/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Canonical URL: bez rozszerzenia .html
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ %1 [R=301,L,NE]

# Strona główna
RewriteRule ^$ index.html [L]

# Clean URLs -> fizyczne pliki .html (również dla ścieżek zagnieżdżonych)
# Przykłady: /kontakt -> /kontakt.html, /blog/slug -> /blog/slug.html
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.+)$ $1.html [L]

ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# --- Twoje Przekierowania ---
# (Tutaj wklej resztę swoich Redirect 301, które miałeś pod spodem)

# --- Przekierowania na konkretne podstrony ---
Redirect 301 /opieka-nad-stronami-www /monitoring-wydajnosci
Redirect 301 /monitoring-pozycji /monitoring-wydajnosci
Redirect 301 /konsultacje-seo /techniczne-seo
Redirect 301 /audyty-seo /techniczne-seo
Redirect 301 /seo-copywriting /content-seo

# --- Przekierowania na stronę główną ---
Redirect 301 /reklama-ppc /
Redirect 301 /pozycjonowanie-lokalne /
Redirect 301 /pozycjonowanie-stron-www /
Redirect 301 /pozycjonowanie-z-rabatem /
Redirect 301 /projektowanie-stron-i-serwisow-www /
Redirect 301 /wydanie-kodow-authinfo /
Redirect 301 /hosting-serwery-wirtualne-ssd-bez-limitu-transferu-danych /
Redirect 301 /google-moja-firma /
Redirect 301 /optymalizacja-stron-www /
Redirect 301 /certyfikaty-ssl /
Redirect 301 /domeny-internetowe /
Redirect 301 /pozycjonowanie-zagraniczne /
Redirect 301 /cesja-domeny /
Redirect 301 /cesja-domeny/ /
Redirect 301 /zmiana-danych-abonenta /
Redirect 301 /pozycjonowanie-sklepow-internetowych /