---
import type { GetStaticPaths, Page } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';
import NewsletterBox from '../../components/NewsletterBox.astro';
import { Image } from 'astro:assets';
import { getAllPosts, getAllCategories, type BlogPost } from '../../lib/wordpress';

export const getStaticPaths = (async ({ paginate }) => {
  // Pobierz WSZYSTKIE wpisy z GraphQL
  const allPosts = await getAllPosts();

  // Użyj natywnej funkcji paginate z Astro - 12 wpisów na stronę
  return paginate(allPosts, {
    pageSize: 12,
  });
}) satisfies GetStaticPaths;

// Pobierz dane paginacji z Astro
const { page } = Astro.props as { page: Page<BlogPost> };

// Pobierz kategorie
const categories = await getAllCategories();

// Podziel wpisy: pierwszy jako wyróżniony (tylko na stronie 1), reszta do siatki
const featuredPost = page.currentPage === 1 ? page.data[0] : null;
const gridPosts = page.currentPage === 1 ? page.data.slice(1) : page.data;

// Skróć excerpt dla wyróżnionego artykułu
const featuredExcerpt = featuredPost?.excerpt
  ? featuredPost.excerpt.substring(0, 200).trim() + '...'
  : '';

// Aktualny pathname dla aktywnych stanów kategorii
const currentPath = Astro.url.pathname;

// Przygotuj numery stron do wyświetlenia w paginacji
const paginationPages = Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => {
  const showPage =
    pageNum === 1 ||
    pageNum === page.lastPage ||
    Math.abs(pageNum - page.currentPage) <= 1;

  const showEllipsisBefore =
    pageNum === page.currentPage - 2 && page.currentPage > 3;
  const showEllipsisAfter =
    pageNum === page.currentPage + 2 && page.currentPage < page.lastPage - 2;

  const pageUrl = pageNum === 1 ? '/blog' : `/blog/${pageNum}`;
  const isCurrentPage = pageNum === page.currentPage;

  return {
    pageNum,
    showPage,
    showEllipsisBefore,
    showEllipsisAfter,
    pageUrl,
    isCurrentPage,
  };
});
---

<BaseLayout
  title={page.currentPage === 1 ? "Blog SEO - Aktualności i Poradniki | Talem" : `Blog SEO - Strona ${page.currentPage} | Talem`}
  description="Najnowsze artykuły o SEO, e-commerce i marketingu internetowym. Eksperckie porady, case studies i strategie zwiększające widoczność w Google."
>
  <Navigation />

  <main class="min-h-screen pt-24 pb-16 bg-gray-50">
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">

      <!-- SEKCJA 1: Wyróżniony artykuł (TYLKO na stronie 1) -->
      {featuredPost && page.currentPage === 1 && (
        <section class="mb-16">
          <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-gray-200 hover:shadow-lg transition-shadow duration-300">
            <div class="grid lg:grid-cols-2 gap-0">
              <!-- Zdjęcie po lewej -->
              {featuredPost.featuredImage?.url && (
                <a
                  href={`/blog/${featuredPost.slug}`}
                  class="block overflow-hidden h-full min-h-[400px]"
                >
                  <Image
                    src={featuredPost.featuredImage.url}
                    alt={featuredPost.featuredImage.alt}
                    width={featuredPost.featuredImage.width || 1200}
                    height={featuredPost.featuredImage.height || 800}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                    loading="eager"
                  />
                </a>
              )}

              <!-- Treść po prawej -->
              <div class="p-8 lg:p-12 flex flex-col justify-center">
                <span class="inline-block px-3 py-1 bg-accent/10 text-accent text-xs font-mono uppercase tracking-wider rounded-full mb-4 w-fit">
                  ARTYKUŁ WYRÓŻNIONY
                </span>

                {featuredPost.categories?.[0] && (
                  <span class="text-accent text-sm font-semibold mb-2 uppercase tracking-wide">
                    {featuredPost.categories[0].name}
                  </span>
                )}

                <h1 class="text-3xl lg:text-4xl font-bold text-black leading-tight mb-4">
                  {featuredPost.title}
                </h1>

                <p class="text-gray-600 text-base leading-relaxed mb-6">
                  {featuredExcerpt}
                </p>

                <div class="flex items-center gap-4 text-sm text-gray-500 mb-6">
                  <time datetime={featuredPost.date} class="flex items-center gap-1.5">
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                      <line x1="16" y1="2" x2="16" y2="6" />
                      <line x1="8" y1="2" x2="8" y2="6" />
                      <line x1="3" y1="10" x2="21" y2="10" />
                    </svg>
                    {featuredPost.formattedDate}
                  </time>
                  <span class="flex items-center gap-1.5">
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                    {featuredPost.readingTime}
                  </span>
                </div>

                <a
                  href={`/blog/${featuredPost.slug}`}
                  class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-white font-bold rounded-lg hover:bg-black transition-colors w-fit group"
                >
                  CZYTAJ WIĘCEJ
                  <svg
                    class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- SEKCJA 2: Pasek nawigacji kategorii + Sortowanie -->
      <section class="mb-10">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 pb-6 border-b border-gray-200">
          <!-- Kategorie -->
          <nav class="flex flex-wrap gap-2" aria-label="Filtruj po kategorii">
            <a
              href="/blog"
              class={`px-4 py-2 font-medium text-sm rounded-full transition-colors ${
                currentPath === '/blog' || currentPath.startsWith('/blog/')
                  ? 'bg-accent text-white'
                  : 'bg-white text-gray-700 border border-gray-200 hover:border-accent hover:text-accent'
              }`}
            >
              WSZYSTKIE
            </a>
            {categories.map((category) => {
              const categoryPath = `/blog/kategoria/${category.slug}`;
              const isActive = currentPath.startsWith(categoryPath);

              return (
                <a
                  href={categoryPath}
                  class={`px-4 py-2 font-medium text-sm rounded-full transition-colors ${
                    isActive
                      ? 'bg-accent text-white'
                      : 'bg-white text-gray-700 border border-gray-200 hover:border-accent hover:text-accent'
                  }`}
                >
                  {category.name.toUpperCase()}
                </a>
              );
            })}
          </nav>

          <!-- Dropdown sortowania (statyczny) -->
          <div class="relative">
            <button
              class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium text-gray-700 hover:border-gray-300 transition-colors"
              aria-haspopup="listbox"
              aria-expanded="false"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M3 6h18M7 12h10m-7 6h4" stroke-width="2" stroke-linecap="round" />
              </svg>
              Sortuj według: <strong>Najnowsze</strong>
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M6 9l6 6 6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>
        </div>
      </section>

      <!-- SEKCJA 3: Siatka wpisów z newsletterem na pozycji 6 -->
      <section>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {gridPosts.map((post, index) => {
            const items = [];

            // Dodaj NewsletterBox jako 6. element (index 5) - tylko na stronie 1
            if (index === 5 && page.currentPage === 1) {
              items.push(<NewsletterBox />);
            }

            // Dodaj PostCard
            items.push(<PostCard post={post} />);

            return items;
          })}
        </div>
      </section>

      <!-- SEKCJA 4: Paginacja (Dynamiczna) -->
      {(page.lastPage > 1) && (
        <section class="mt-16">
          <nav
            class="flex items-center justify-center gap-2"
            aria-label="Paginacja"
          >
            {/* Przycisk Poprzednia */}
            {page.url.prev ? (
              <a
                href={page.url.prev}
                class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-accent transition-colors"
                aria-label="Poprzednia strona"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M15 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            ) : (
              <button
                class="px-4 py-2 text-sm font-medium text-gray-400 cursor-not-allowed"
                disabled
                aria-label="Poprzednia strona"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M15 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            )}

            {/* Numery stron */}
            {paginationPages.map((pageData) => {
              if (pageData.showEllipsisBefore || pageData.showEllipsisAfter) {
                return <span class="px-2 text-gray-400">...</span>;
              }

              if (!pageData.showPage) return null;

              return (
                <a
                  href={pageData.pageUrl}
                  class={`px-4 py-2 font-medium text-sm rounded-lg transition-colors ${
                    pageData.isCurrentPage
                      ? 'bg-accent text-white'
                      : 'bg-white text-gray-700 border border-gray-200 hover:border-accent hover:text-accent'
                  }`}
                  aria-current={pageData.isCurrentPage ? 'page' : undefined}
                >
                  {pageData.pageNum}
                </a>
              );
            })}

            {/* Przycisk Następna */}
            {page.url.next ? (
              <a
                href={page.url.next}
                class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-accent transition-colors"
                aria-label="Następna strona"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M9 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            ) : (
              <button
                class="px-4 py-2 text-sm font-medium text-gray-400 cursor-not-allowed"
                disabled
                aria-label="Następna strona"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M9 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
            )}
          </nav>
        </section>
      )}

    </div>
  </main>

  <Footer />
</BaseLayout>
