---
import SectionHeader from '../ui/SectionHeader.astro';
import ServiceCard from '../ui/ServiceCard.astro';
---

<section id="uslugi" class="bg-gray-100 px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto mb-16">
    <SectionHeader label="CO ROBIMY?" title="Kompleksowe rozwiązania SEO <br>dla e-commerce" />
  </div>

  <div class="max-w-[1400px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <ServiceCard
      number="01"
      title="Techniczne SEO dla sklepów internetowych"
      description="Zapewniamy zaawansowane techniczne SEO dla sklepów internetowych i platform e-commerce, wspierające indeksację i wzrost widoczności."
      features={[
        'Audyt techniczny SEO sklepu',
        'Struktura URL-i i linkowanie wewnętrzne',
        'Optymalizacja wydajności i Core Web Vitals',
        'Optymalizacja indeksacji i crawl budgetu',
        'Dane strukturalne i wyniki rozszerzone',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
        <rect x="9" y="9" width="6" height="6"></rect>
        <line x1="9" y1="1" x2="9" y2="4"></line>
        <line x1="15" y1="1" x2="15" y2="4"></line>
        <line x1="9" y1="20" x2="9" y2="23"></line>
        <line x1="15" y1="20" x2="15" y2="23"></line>
        <line x1="20" y1="9" x2="23" y2="9"></line>
        <line x1="20" y1="15" x2="23" y2="15"></line>
        <line x1="1" y1="9" x2="4" y2="9"></line>
        <line x1="1" y1="15" x2="4" y2="15"></line>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="02"
      title="Content SEO dla e-commerce"
      description="Tworzymy architekturę treści SEO opartą na analizie intencji wyszukiwania, która zwiększa widoczność i sprzedaż."
      features={[
        'Analiza potencjału i dobór fraz',
        'Semantyczne mapowanie fraz',
        'Projektowanie struktury kategorii',
        'Tworzenie i optymalizacja treści SEO',
        'Automatyzacje AI i skalowanie contentu',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <line x1="10" y1="9" x2="8" y2="9"></line>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="03"
      title="Migracje sklepów internetowych"
      description="Przeprowadzamy migracje sklepów internetowych z zachowaniem widoczności SEO, struktury ruchu i ciągłości sprzedaży."
      features={[
        'Analiza przedmigracyjna SEO i danych',
        'Mapowanie URL-i i przekierowania 301',
        'Projektowanie struktury nowego sklepu',
        'Migracja treści, kategorii i produktów',
        'Monitoring i optymalizacja po migracji',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m16 3 4 4-4 4"></path>
        <path d="M20 7H4"></path>
        <path d="m8 21-4-4 4-4"></path>
        <path d="M4 17h16"></path>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="04"
      title="Monitorowanie wydajności i jakości serwisu"
      description="Monitorujemy wydajność sklepów na podstawie danych od realnych użytkowników. Identyfikujemy problemy SEO i UX."
      features={[
        'RUM – Real User Monitoring',
        'Monitoring Core Web Vitals',
        'Analiza wydajności na poziomie użytkownika',
        'Wykrywanie problemów wydajnościowych i regresji',
        'Raportowanie rekomendacje optymalizacyjne',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 20a8 8 0 0 0 8-8V4h-8"></path>
        <path d="M12 20a8 8 0 0 1-8-8V4h8"></path>
        <path d="M10 10l2 2 4-4"></path>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="05"
      title="Link building i autorytet domeny"
      description="Budujemy autorytet sklepów poprzez jakościowe linkowanie i sygnały zewnętrzne, wspierające wzrost widoczności w SERP-ach."
      features={[
        'Analiza profilu linków własnych i konkurencji',
        'Opracowanie strategii link buildingu',
        'Pozyskiwanie linków kontekstowych i contentowych',
        'Budowanie linków brandowych',
        'Oczyszczanie profilu linków',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
      </svg>
    </ServiceCard>

    <ServiceCard
      number="06"
      title="Analityka SEO i automatyzacja AI"
      description="Wspieramy decyzje SEO danymi analitycznymi z zakresu prognozowania wzrostu widoczności i sprzedaży z ruchu organicznego."
      features={[
        'Analityka SEO dla e-commerce',
        'Konfiguracji i audyty GA4 i GSC',
        'Segmentacja danych SEO (kategorie, produkty, intencje)',
        'Prognozowanie potencjału wzrostów i konwersji',
        'Automatyzacja AI, dashboardy SEO i raporty decyzyjne',
      ]}
      link="#"
    >
      <svg
        slot="icon"
        aria-hidden="true"
        width="40"
        height="40"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="12" y1="20" x2="12" y2="10"></line>
        <line x1="18" y1="20" x2="18" y2="4"></line>
        <line x1="6" y1="20" x2="6" y2="16"></line>
      </svg>
    </ServiceCard>
  </div>
</section>
