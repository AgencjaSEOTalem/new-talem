---
import { Image } from 'astro:assets';
import type { BlogPost } from '../lib/wordpress';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

// Pobierz pierwszą kategorię
const primaryCategory = post.categories?.[0];

// Przygotuj excerpt (skrócony do ~120 znaków)
const shortExcerpt =
  post.excerpt.length > 120 ? post.excerpt.substring(0, 120).trim() + '...' : post.excerpt;
---

<article
  class="group h-full flex flex-col bg-white rounded-lg overflow-hidden border border-gray-200 hover:border-accent/30 hover:shadow-lg transition-all duration-300"
>
  <!-- Zdjęcie -->
  {
    post.featuredImage?.url && (
      <a href={`/blog/${post.slug}`} class="block overflow-hidden aspect-[16/10]">
        <img
          src={post.featuredImage.url}
          alt={post.featuredImage.alt}
          width={post.featuredImage.width || 800}
          height={post.featuredImage.height || 500}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </a>
    )
  }

  <!-- Treść karty -->
  <div class="p-6 flex flex-col flex-grow">
    <!-- Kategoria -->
    {
      primaryCategory && (
        <span class="text-accent text-xs font-mono uppercase tracking-wider mb-2 block">
          {primaryCategory.name}
        </span>
      )
    }

    <!-- Tytuł -->
    <div class="mb-3">
      <a
        href={`/blog/${post.slug}`}
        class="text-xl font-bold text-black leading-tight hover:text-accent transition-colors duration-200 line-clamp-2 block"
      >
        {post.title}
      </a>
    </div>

    <!-- Excerpt -->
    <p class="text-gray-600 text-sm leading-relaxed mb-4 flex-grow line-clamp-3">
      {shortExcerpt}
    </p>

    <!-- Meta informacje (Data + Czas czytania) -->
    <div class="flex items-center gap-4 text-xs text-gray-500 pt-4 border-t border-gray-100">
      {
        /*<time datetime={post.date} class="flex items-center gap-1.5">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        {post.formattedDate}
      </time>*/
      }
      <span class="flex items-center gap-1.5">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        {post.readingTime}
      </span>
    </div>
  </div>
</article>
