---
import SectionHeader from '../ui/SectionHeader.astro';

const services = [
  {
    title: "Analiza danych i planowanie strategii migracji",
    description: "Analizujemy aktualną widoczność, ruch organiczny, strukturę adresów URL oraz strony generujące sprzedaż. Identyfikujemy kluczowe podstrony, źródła ruchu i elementy wymagające szczególnej ochrony. Na tej podstawie tworzymy plan działań minimalizujący ryzyko spadków widoczności i utraty przychodów.",
    icon: "chart"
  },
  {
    title: "Projektowanie architektury SEO nowego sklepu",
    description: "Projektujemy strukturę kategorii, adresów URL oraz logikę linkowania wewnętrznego tak, aby nowy sklep był czytelny dla użytkowników i wyszukiwarek. Dbamy o zachowanie logiki, hierarchii treści i skalowalności serwisu.",
    icon: "structure"
  },
  {
    title: "Weryfikacja techniczna przed migracją",
    description: "Weryfikujemy nową wersję sklepu jeszcze przed uruchomieniem: strukturę adresów URL, meta dane, indeksację, linkowanie wewnętrzne, wydajność oraz potencjalne błędy techniczne. Dzięki temu minimalizujemy ryzyko spadków widoczności po wdrożeniu nowej struktury.",
    icon: "check"
  },
  {
    title: "Mapowanie adresów URL i wdrażanie przekierowań 301",
    description: "Przygotowujemy szczegółową mapę starych i nowych adresów URL, uwzględniając nie tylko strukturę serwisu, ale także podstrony generujące ruch i sprzedaż. Wdrażamy przekierowania (301), które chronią wypracowaną widoczność, moc linków i doświadczenie użytkownika.",
    icon: "redirect"
  },
  {
    title: "Przeniesienie treści i elementów SEO",
    description: "Zapewniamy poprawne przeniesienie treści, metadanych, nagłówków, opisów kategorii i produktów oraz innych elementów wpływających na ranking. Dbamy o zachowanie spójności semantycznej i unikanie utraty wartości SEO.",
    icon: "content"
  },
  {
    title: "Nadzór wdrożenia nowej struktury",
    description: "Nadzorujemy proces uruchomienia, weryfikując działanie przekierowań, indeksację, dostępność stron, statusy odpowiedzi serwera (4xx / 5xx) oraz zachowanie robotów wyszukiwarek. Pozwala to wychwycić krytyczne błędy zanim wpłyną na widoczność.",
    icon: "monitor"
  },
  {
    title: "Monitoring widoczności i działania po migracji",
    description: "Po uruchomieniu sklepu monitorujemy indeksację, ruch i pozycje, analizując reakcję wyszukiwarek na nową wersję serwisu. W przypadku spadków szybko identyfikujemy przyczyny i wdrażamy korekty, ograniczając ryzyko strat biznesowych.",
    icon: "tracking"
  }
];

const icons: Record<string, string> = {
  chart: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
  structure: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  redirect: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>`,
  content: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
  monitor: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  tracking: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>`
};
---

<section class="py-20 bg-slate-950">
  <div class="container mx-auto px-4">
    <SectionHeader
      title="Co robimy w ramach migracji sklepu"
      align="center"
      theme="dark"
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {services.map((service) => (
        <div class="group p-6 rounded-2xl bg-slate-900/50 border border-slate-800 hover:border-amber-500/30 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 mb-4 group-hover:bg-amber-500/20 transition-colors">
            <Fragment set:html={icons[service.icon]} />
          </div>
          <h3 class="text-lg font-semibold text-white mb-3">{service.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
